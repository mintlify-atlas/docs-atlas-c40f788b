  "keyFeatures": [
    "Pre-execution policy enforcement with PERMIT/DENY/DEFER decisions",
    "Policy-as-code with YAML and expr-lang expression evaluation",
    "Tamper-evident DPR (Decision-Provenance Record) audit chain",
    "WAL-first ordering guarantees no execution without audit record",
    "Human-in-the-loop DEFER workflow for approval-required actions",
    "Six deployment adapters from SDK shim to eBPF kernel probes",
    "Multi-agent governance with session state and budget management",
    "Credential brokering and workload identity integration"
  ],
  "publicApiSurface": [
    "govern() - Python decorator for wrapping callable functions",
    "faramesh demo - Interactive demonstration command",
    "faramesh serve - Start governance daemon",
    "faramesh policy validate - Validate policy files",
    "faramesh audit tail - Stream live governance decisions",
    "faramesh agent approve/deny - Resolve DEFER actions",
    "faramesh agent kill - Activate agent kill switch",
    "CanonicalActionRequest - Core request type",
    "Decision - Governance decision type with Effect (PERMIT/DENY/DEFER)",
    "Policy YAML schema - Rules, conditions, effects, reason codes"
  ]
}
